        local data = decJ(d)
        if data.MagOn        ~= nil then MagOn        = data.MagOn        end
        if data.MagSize      ~= nil then MagSize      = data.MagSize      end
        if data.ReachOn      ~= nil then ReachOn      = data.ReachOn      end
