-- ‚ĒÄ‚ĒÄ MAG LOOP ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
conn(RS.Stepped, function()
    if Unloaded then return end
    local char = LP.Character; if not char then return end
    local cl = char:FindFirstChild("CatchLeft")
    local cr = char:FindFirstChild("CatchRight")
    if not cl or not cr then return end

    local magActive = MagOn and (not MagLMBOnly or lmbHeld)
    local sz

    if magActive then
        sz = MagSize
    elseif ReachOn then
        sz = ReachSz
    end

    if sz then
        local sv = Vector3.new(sz, sz, sz)
        pcall(function()
            cl.Size = sv; cr.Size = sv
            cl.Transparency = 1; cr.Transparency = 1
            cl.CanCollide = false; cr.CanCollide = false
            cl.CanQuery = false; cr.CanQuery = false
            cl.CanTouch = true; cr.CanTouch = true
            cl.Massless = true; cr.Massless = true
            cl.Material = Enum.Material.SmoothPlastic
            cr.Material = Enum.Material.SmoothPlastic
        end)
    else
        pcall(function()
            if cl.Size.X ~= 1 then cl.Size = Vector3.new(1,1,1) end
            if cr.Size.X ~= 1 then cr.Size = Vector3.new(1,1,1) end
            cl.Transparency = 0; cr.Transparency = 0
            cl.CanCollide = true; cr.CanCollide = true
            cl.CanTouch = true; cr.CanTouch = true
        end)
    end

    -- FIX 3: removed task.wait() ‚ÄĒ was yielding inside Stepped causing desynced touch events
    -- Both fire/unfires now happen synchronously in the same frame
    if magActive and typeof(firetouchinterest) == "function" then
        -- Use cached _ball directly here ‚ÄĒ avoid rescanning workspace every frame
        local ball = (_ball and _ball.Parent) and _ball or nil
        if not ball then
            for _, v in ipairs(workspace:GetChildren()) do
                if v.Name == "Football" and v:IsA("BasePart") then ball = v; _ball = v; break end
            end
        end
        if ball then
            pcall(function()
                firetouchinterest(cl, ball, 0)
                firetouchinterest(cr, ball, 0)
                firetouchinterest(cl, ball, 1)
                firetouchinterest(cr, ball, 1)
            end)
        end
    end
end)

