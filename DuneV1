    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Text = txt
    if tip then
        local tb = mkTip(row, tip); tb.AnchorPoint = Vector2.new(0,.5)
        tb.Position = UDim2.new(1,-58,.5,0)
    end
    local state = def
    local function setV(v)
        state = v
        tw(box,  {BackgroundColor3 = v and T.acc or T.btn},  .12)
        tw(sk,   {Color            = v and T.acc or T.bdr},  .12)
        tw(knob, {Position=UDim2.new(v and .75 or .25,0,.5,0), BackgroundColor3=v and T.bg or T.TD}, .12)
        tw(lbl,  {TextColor3       = v and T.TP  or T.TSub}, .12)
    end
    local cl = Instance.new("TextButton", row)
    cl.Size = UDim2.new(1,0,1,0); cl.BackgroundTransparency = 1; cl.Text = ""
    conn(cl.MouseButton1Click, function()
        state = not state; setV(state); cb(state)
