-- ‚ĒÄ‚ĒÄ HEARTBEAT ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
conn(RS.Heartbeat, function()
    if Unloaded then return end
    local char  = LP.Character
    local hum   = char and char:FindFirstChildOfClass("Humanoid")
    local hrp   = char and char:FindFirstChild("HumanoidRootPart")
    local ball  = getBall()

    -- ‚ĒÄ‚ĒÄ HUMANOID ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if hum then
        if InfStamHighOn then
            if hum.WalkSpeed ~= 26 then hum.WalkSpeed = 26 end
            if hum.JumpPower ~= 60  then hum.JumpPower = 60  end
        elseif InfStamLowOn then
            if hum.WalkSpeed ~= WS  then hum.WalkSpeed = WS  end
            if hum.JumpPower ~= JP  then hum.JumpPower = JP  end
        else
            if hum.WalkSpeed ~= WS  then hum.WalkSpeed = WS  end
            if hum.JumpPower ~= JP  then hum.JumpPower = JP  end
        end
        if HipH ~= 0 and hum.HipHeight ~= HipH then hum.HipHeight = HipH end
        if NoJumpCD then pcall(function() hum:SetAttribute("JumpCooldownTimer", 0) end) end
        if AutoGetUpOn then
            local st = hum:GetState()
            if st==Enum.HumanoidStateType.FallingDown
            or st==Enum.HumanoidStateType.Ragdoll
            or st==Enum.HumanoidStateType.GettingUp then
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
    end

    -- ‚ĒÄ‚ĒÄ CFRAME MOVE ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if CFMoveOn and hrp then
        local mv = Vector3.zero
        if UIS:IsKeyDown(Enum.KeyCode.W) then mv += Cam.CFrame.LookVector  end
        if UIS:IsKeyDown(Enum.KeyCode.S) then mv -= Cam.CFrame.LookVector  end
        if UIS:IsKeyDown(Enum.KeyCode.A) then mv -= Cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then mv += Cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space)     then mv += Vector3.new(0,1,0) end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then mv -= Vector3.new(0,1,0) end
        if mv.Magnitude > 0 then hrp.CFrame = hrp.CFrame + mv.Unit*CFSpd*(1/60) end
    end

    -- ‚ĒÄ‚ĒÄ FLY ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if FlyOn and hrp then
        if not flyBV then
            pcall(function()
                local att = Instance.new("Attachment", hrp); att.Name = "DuneFlyAtt"
                flyBV = Instance.new("BodyVelocity", hrp)
                flyBV.Name = "DuneFlyBV"; flyBV.MaxForce = Vector3.new(1e6,1e6,1e6)
                flyBV.Velocity = Vector3.zero
            end)
        end
        if flyBV then
            local mv = Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W) then mv += Cam.CFrame.LookVector  end
            if UIS:IsKeyDown(Enum.KeyCode.S) then mv -= Cam.CFrame.LookVector  end
            if UIS:IsKeyDown(Enum.KeyCode.A) then mv -= Cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then mv += Cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space)     then mv += Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then mv -= Vector3.new(0,1,0) end
            pcall(function() flyBV.Velocity = mv.Magnitude>0 and mv.Unit*FlySpd or Vector3.zero end)
        end
    elseif flyBV then
        pcall(function() flyBV:Destroy() end); flyBV = nil
    end

    -- ‚ĒÄ‚ĒÄ PULL VECTOR ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local ballInAir = ball and getBallCarrier() == nil and ball.AssemblyLinearVelocity.Magnitude > 3
    if PullOn and rmbHeld and ball and hrp and ballInAir then
        local ballVel  = ball.AssemblyLinearVelocity
        local dist     = (ball.Position - hrp.Position).Magnitude
        -- predict 180ms ahead so you arrive where ball will be
        local predicted = ball.Position + ballVel * 0.18 + Vector3.new(0, 2, 0)
        if PullMode == 2 then
            -- Instant: always TP, no ballInAir check, no distance cap
            pcall(function()
                hrp.CFrame = CFrame.new(predicted)
            end)
        else
            -- Smooth: much stronger alpha so it actually keeps up
            if dist > 2 then
                local alpha = math.clamp(PullStr * 0.06, 0.06, 0.55)
                pcall(function()
                    hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(predicted), alpha)
                end)
            end
        end
    end


    -- ‚ĒÄ‚ĒÄ TACKLE REACH ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if char and TackleReachOn then
        local now = tick()
        if not _tackleReachTick or now - _tackleReachTick >= 0.25 then
            _tackleReachTick = now
            for _, v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") and (v.Name:lower():find("tackle") or v.Name:lower():find("hitbox") or v.Name:lower():find("slide")) then
                    local sv = Vector3.new(TackleReachSz, TackleReachSz, TackleReachSz)
                    pcall(function()
                        v.Size = sv; v.Transparency = 1
                        v.CanCollide = false; v.CanQuery = false
                    end)
                end
            end
        end
    end

    -- ‚ĒÄ‚ĒÄ AUTO FOLLOW / AUTO SACK ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if hrp then
        local carrier = getBallCarrier()
        if carrier and carrier ~= LP then
            local cHRP = carrier.Character and carrier.Character:FindFirstChild("HumanoidRootPart")
            if cHRP then
                local dist = (cHRP.Position - hrp.Position).Magnitude
                if AutoFollowOn then
                    if TPTackleOn then
                        pcall(function() hrp.CFrame = CFrame.new(cHRP.Position + Vector3.new(0,0,2)) end)
                    else
                        local alpha = math.clamp(0.15 + (1 / math.max(dist, 1)) * 2, 0.15, 0.5)
                        pcall(function() hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(cHRP.Position + Vector3.new(0,0,2)), alpha) end)
                    end
                end
                if AutoSackOn and dist <= 25 then
                    local carrierIsEnemy = carrier.Team == nil or carrier.Team ~= LP.Team
                    if carrierIsEnemy then
                        pcall(function() hrp.CFrame = CFrame.new(cHRP.Position + Vector3.new(0,0,1.5)) end)
                    end
                end
            end
        end
    end

    -- ‚ĒÄ‚ĒÄ ANTI BLOCK ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if AntiBlock1On or AntiBlock2On then
        local now = tick()
        if not _antiBlockTick or now - _antiBlockTick >= 0.5 then
            _antiBlockTick = now
            for _, p in ipairs(Players:GetPlayers()) do
                if p == LP then continue end
                local pchar = p.Character; if not pchar then continue end
                for _, v in ipairs(pchar:GetDescendants()) do
                    if v:IsA("BasePart") then
                        local n = v.Name:lower()
                        if AntiBlock1On and (n:find("block") or n:find("shield") or n:find("protect")) then
                            pcall(function() v.Size = Vector3.new(0.01,0.01,0.01) end)
                        end
                        if AntiBlock2On and (n:find("blocker") or n:find("wall") or n:find("barrier")) then
                            pcall(function() v.Size = Vector3.new(0.01,0.01,0.01) end)
                        end
                    end
                end
            end
        end
    end

end) -- end Heartbeat
