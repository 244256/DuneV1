    dll.Padding = UDim.new(0, 2); dll.SortOrder = Enum.SortOrder.LayoutOrder
    local dlp = Instance.new("UIPadding", dl)
    dlp.PaddingTop = UDim.new(0, 4); dlp.PaddingBottom = UDim.new(0, 4)
    dlp.PaddingLeft = UDim.new(0, 4); dlp.PaddingRight = UDim.new(0, 4)

    local open = false

    local function updateColors()
        for _, ch in ipairs(dl:GetChildren()) do
            if ch:IsA("TextButton") then
                ch.TextColor3 = ch.Text == opts[curIdx] and T.acc or T.TSub
            end
        end
    end

    local function close()
        if not open then return end
        open = false
        local w = dl.AbsoluteSize.X
        tw(dl, {Size = UDim2.fromOffset(w, 0)}, .12)
        task.delay(.13, function() if not open then dl.Visible = false end end)
        tw(chv, {Rotation = 0}, .12)
    end

    for i, opt in ipairs(opts) do
        local it = Instance.new("TextButton", dl)
        it.LayoutOrder = i; it.Size = UDim2.new(1, 0, 0, 24); it.BackgroundColor3 = T.btn
        it.Font = Enum.Font.Gotham; it.TextSize = 11; it.TextColor3 = i==curIdx and T.acc or T.TSub
        it.TextXAlignment = Enum.TextXAlignment.Left; it.Text = opt; it.BorderSizePixel = 0
        it.ZIndex = 201; corner(it, UDim.new(0, 5))
        Instance.new("UIPadding", it).PaddingLeft = UDim.new(0, 8)
        conn(it.MouseEnter, function() tw(it, {BackgroundColor3=T.btnH}, .1) end)
        conn(it.MouseLeave, function() tw(it, {BackgroundColor3=T.btn}, .1) end)
        conn(it.MouseButton1Click, function()
            curIdx = i
            btn.Text = opt   -- update the button label immediately
            cb(i)
            updateColors()
            close()
        end)
    end

    conn(btn.MouseButton1Click, function()
        if open then close(); return end
        local ap = btn.AbsolutePosition
        local as = btn.AbsoluteSize
        if as.X == 0 then return end  -- not yet rendered, skip
        open = true
        dl.Size = UDim2.fromOffset(as.X, 0)
        dl.Position = UDim2.fromOffset(ap.X, ap.Y + as.Y + 2)
        dl.Visible = true
        tw(dl, {Size = UDim2.fromOffset(as.X, lh)}, .14)
        tw(chv, {Rotation = 180}, .14)
    end)

    conn(UIS.InputBegan, function(i)
        if not open then return end
        if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        task.defer(function()
            if not open then return end
            local mp  = UIS:GetMouseLocation()
            local dp  = dl.AbsolutePosition;  local ds = dl.AbsoluteSize
            local bp  = btn.AbsolutePosition; local bs = btn.AbsoluteSize
            if not (mp.X>=dp.X and mp.X<=dp.X+ds.X and mp.Y>=dp.Y and mp.Y<=dp.Y+ds.Y)
            and not (mp.X>=bp.X and mp.X<=bp.X+bs.X and mp.Y>=bp.Y and mp.Y<=bp.Y+bs.Y) then
                close()
            end
        end)
    end)
end



