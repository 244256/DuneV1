conn(RS.RenderStepped, function()
    if Unloaded then return end
    FL.Text = "‚óŹ " .. #Players:GetPlayers() .. " players"

    local myHRP = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    local ball  = getBall()


    -- ‚ĒÄ‚ĒÄ BALL PREDICTION LINE ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if BallPredOn and ball and ballPredLine and ballPredDot then
        local vel = ball.AssemblyLinearVelocity
        if vel.Magnitude > 4 then
            local GRAVITY   = Vector3.new(0, -workspace.Gravity, 0)
            local SIM_STEPS = 30
            local SIM_DT    = 0.06
            local pos = ball.Position
            local v   = vel
            local landPos = nil

            for _ = 1, SIM_STEPS do
                v   = v + GRAVITY * SIM_DT
                pos = pos + v * SIM_DT
                if pos.Y < 3 then
                    landPos = pos
                    break
                end
            end
            if not landPos then landPos = pos end

            local bSP, bOn, bD = Cam:WorldToViewportPoint(ball.Position)
            local lSP, lOn, lD = Cam:WorldToViewportPoint(landPos)

            if bOn and lOn and bD > 0 and lD > 0 then
                pcall(function()
                    ballPredLine.From    = Vector2.new(bSP.X, bSP.Y)
                    ballPredLine.To      = Vector2.new(lSP.X, lSP.Y)
                    ballPredLine.Visible = true
                    ballPredDot.Position = Vector2.new(lSP.X, lSP.Y)
                    ballPredDot.Visible  = true
                end)
            else
                pcall(function()
                    ballPredLine.Visible = false
                    ballPredDot.Visible  = false
                end)
            end
        else
            pcall(function()
                ballPredLine.Visible = false
                ballPredDot.Visible  = false
            end)
        end
    elseif ballPredLine then
        pcall(function() ballPredLine.Visible = false end)
        pcall(function() if ballPredDot then ballPredDot.Visible = false end end)
    end
end)

