-- ‚ĒÄ‚ĒÄ MAG LOOP ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
-- CONFIRMED WORKING METHOD (high-unc executors like Xeno/Synapse):
-- Directly set ball.CFrame to your character position every frame.
-- This is what real NFL Universe Football scripts (OpenSource, Kali Hub) do.
-- firetouchinterest was never going to work ‚ÄĒ the game uses server-side overlap,
-- not the Touched event. Direct CFrame write is the only client-side approach.

local ARM_PARTS = {"LeftHand","RightHand","LeftLowerArm","RightLowerArm","LeftUpperArm","RightUpperArm"}
local _armOrigSizes = {}
local _armOrigTrans = {}

local function saveArmOriginals(char)
    for _, name in ipairs(ARM_PARTS) do
        local p = char:FindFirstChild(name)
        if p and not _armOrigSizes[name] then
            _armOrigSizes[name] = p.Size
            _armOrigTrans[name] = p.Transparency
        end
    end
end

local function applyArmReach(char, sz)
    -- sz slider: 10=normal, 20=subtle, 40=obvious, 50=very long
    -- Scale arms on ALL axes so they look thick AND long (not just thin stretched noodles)
    local scale = sz / 10  -- 1.0 at 10, 5.0 at 50
    for _, name in ipairs(ARM_PARTS) do
        local p = char:FindFirstChild(name)
        if p then
            pcall(function()
                local orig = _armOrigSizes[name] or p.Size
                -- Scale Y (length) more than X/Z so it looks like long arms, not balloons
                p.Size = Vector3.new(orig.X * math.max(1, scale * 0.6), orig.Y * scale, orig.Z * math.max(1, scale * 0.6))
                p.Transparency = 0
            end)
        end
    end
    -- Also extend CatchLeft/CatchRight hitbox to match arm reach
    -- so the catch actually registers further out
    local catchSz = sz * 2  -- arm at 20 = 40 stud hitbox, arm at 50 = 100 stud hitbox
    for _, name in ipairs({"CatchLeft", "CatchRight"}) do
        local p = char:FindFirstChild(name)
        if p then
            pcall(function()
                local sv = Vector3.new(catchSz, catchSz, catchSz)
                p.Size = sv
                p.CanTouch = true
                p.CanCollide = false
                p.CanQuery = false
                p.Massless = true
            end)
        end
    end
end

local function resetArmReach(char)
    for _, name in ipairs(ARM_PARTS) do
        local p = char:FindFirstChild(name)
        if p then
            pcall(function()
                if _armOrigSizes[name] then
                    p.Size = _armOrigSizes[name]
                    p.Transparency = _armOrigTrans[name] or 0
                end
            end)
        end
    end
    _armOrigSizes = {}
    _armOrigTrans = {}
end

-- Long Arms loop: visually extend arm parts every frame
conn(RS.Stepped, function()
    if Unloaded then return end
    local char = LP.Character; if not char then return end
    if ReachOn then
        saveArmOriginals(char)
        applyArmReach(char, ReachSz)
    else
        if next(_armOrigSizes) ~= nil then
            resetArmReach(char)
        end
    end
end)

