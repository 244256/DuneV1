local function unload()
    if Unloaded then return end; Unloaded = true
    for _, c in ipairs(angleConns) do pcall(function() c:Disconnect() end) end
    if ballPredLine  then pcall(function() ballPredLine:Remove()  end); ballPredLine  = nil end
    if ballPredDot   then pcall(function() ballPredDot:Remove()   end); ballPredDot   = nil end
    for ball, _ in pairs(_ballFFParts) do destroyBallFF(ball) end
    if flyBV then
        pcall(function()
            -- FIX: also clean up the leaked DuneFlyAtt attachment
            local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local att = hrp:FindFirstChild("DuneFlyAtt")
                if att then att:Destroy() end
            end
            flyBV:Destroy()
        end)
        flyBV = nil
    end
    if LP.Character then
        for _, n in ipairs({"CatchLeft","CatchRight"}) do
            local pt = LP.Character:FindFirstChild(n)
            if pt then pcall(function() pt.Size=Vector3.new(1,1,1); pt.Transparency=0; pt.CanCollide=true; pt.CanQuery=true end) end
        end
        for _, v in ipairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") and v.Name:lower():find("tackle") then
                pcall(function() v.Size=Vector3.new(1,1,1) end)
            end
        end
    end
    -- Disconnect all ball Destroying watchers
    for ball, c in pairs(_ballConns) do
        pcall(function() c:Disconnect() end)
        _ballConns[ball] = nil
    end
    for _, c in ipairs(Conns) do pcall(function() c:Disconnect() end) end
    SG:Destroy()
end
