    pcall(function() if typeof(makefolder)=="function" then pcall(function() if not isfolder("Dune") then makefolder("Dune") end end) end end)

    local function encJ(t)
        local p={}
        for k,v in pairs(t) do
            local val
            if type(v)=="boolean" then val = v and "true" or "false"
            elseif type(v)=="number" then val = tostring(v)
            else val = '"'..tostring(v):gsub('\\','\\\\'):gsub('"','\\"')..'"' end
            table.insert(p, '"'..k..'":' ..val)
        end
        return "{"..table.concat(p,",").."}"
    end

    -- FIX: loadC now actually parses and applies saved values
    local function decJ(str)
        local result = {}
        for key, val in str:gmatch('"([^"]+)":%s*([^,}]+)') do
            val = val:match("^%s*(.-)%s*$")
            if val == "true" then result[key] = true
            elseif val == "false" then result[key] = false
            else
                local n = tonumber(val)
                if n then result[key] = n
                else result[key] = val:match('^"(.*)"$') or val end
            end
        end
        return result
    end

    local function saveC()
        if typeof(writefile)~="function" then Notify("Config","writefile unavailable"); return end
        pcall(writefile, cf, encJ({
            ReachOn=ReachOn, ReachSz=ReachSz,
            WS=WS, JP=JP, InfStamHighOn=InfStamHighOn, InfStamLowOn=InfStamLowOn,
            AutoGetUpOn=AutoGetUpOn, AutoFollowOn=AutoFollowOn,
            TackleReachOn=TackleReachOn, TackleReachSz=TackleReachSz
        }))
        Notify("Config","Saved to "..cf)
    end

    local function loadC()
        if typeof(readfile)~="function" then Notify("Config","readfile unavailable"); return end
        local ok, d = pcall(readfile, cf)
        if not (ok and d and #d > 2) then Notify("Config","No save found"); return end
        local data = decJ(d)
        if data.ReachOn      ~= nil then ReachOn      = data.ReachOn      end
        if data.ReachSz      ~= nil then ReachSz      = data.ReachSz      end
        if data.WS           ~= nil then WS           = data.WS           end
        if data.JP           ~= nil then JP           = data.JP           end
        if data.InfStamHighOn ~= nil then InfStamHighOn = data.InfStamHighOn end
        if data.InfStamLowOn  ~= nil then InfStamLowOn  = data.InfStamLowOn  end
        if data.AutoGetUpOn  ~= nil then AutoGetUpOn  = data.AutoGetUpOn  end
        if data.AutoFollowOn ~= nil then AutoFollowOn = data.AutoFollowOn end
        if data.TackleReachOn ~= nil then TackleReachOn = data.TackleReachOn end
        if data.TackleReachSz ~= nil then TackleReachSz = data.TackleReachSz end
        Notify("Config","Config loaded from save")
    end

    local function ABtn(lbl, col, o, fn)
        local b = Instance.new("TextButton", br); b.LayoutOrder=o; b.Size=UDim2.new(.5,-4,1,0)
