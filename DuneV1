-- ── HEARTBEAT ──────────────────────────────────────────────────────────────
conn(RS.Heartbeat, function()
    if Unloaded then return end
    local char = LP.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local ball = getBall()

    -- ── HUMANOID ──────────────────────────────────────────────────────────
    if hum then
        if InfStamHighOn then
            if hum.WalkSpeed ~= 26 then hum.WalkSpeed = 26 end
            if hum.JumpPower ~= 60  then hum.JumpPower = 60 end
        elseif InfStamLowOn then
            if hum.WalkSpeed ~= WS then hum.WalkSpeed = WS end
            if hum.JumpPower ~= JP then hum.JumpPower = JP end
        else
            if hum.WalkSpeed ~= WS then hum.WalkSpeed = WS end
            if hum.JumpPower ~= JP then hum.JumpPower = JP end
        end
        if HipH ~= 0 and hum.HipHeight ~= HipH then hum.HipHeight = HipH end
        if NoJumpCD then pcall(function() hum:SetAttribute("JumpCooldownTimer", 0) end) end
        if AutoGetUpOn then
            local st = hum:GetState()
            if st==Enum.HumanoidStateType.FallingDown
            or st==Enum.HumanoidStateType.Ragdoll
            or st==Enum.HumanoidStateType.GettingUp then
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end
    end

    -- ── CFRAME MOVE ───────────────────────────────────────────────────────
    if CFMoveOn and hrp then
        local mv = Vector3.zero
        if UIS:IsKeyDown(Enum.KeyCode.W)         then mv = mv + Cam.CFrame.LookVector  end
        if UIS:IsKeyDown(Enum.KeyCode.S)         then mv = mv - Cam.CFrame.LookVector  end
        if UIS:IsKeyDown(Enum.KeyCode.A)         then mv = mv - Cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D)         then mv = mv + Cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.Space)     then mv = mv + Vector3.new(0,1,0)     end
        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then mv = mv - Vector3.new(0,1,0)     end
        if mv.Magnitude > 0 then hrp.CFrame = hrp.CFrame + mv.Unit*CFSpd*(1/60) end
    end

    -- ── FLY ───────────────────────────────────────────────────────────────
    if FlyOn and hrp then
        if not flyBV then
            pcall(function()
                local att=Instance.new("Attachment",hrp); att.Name="DuneFlyAtt"
                flyBV=Instance.new("BodyVelocity",hrp)
                flyBV.Name="DuneFlyBV"; flyBV.MaxForce=Vector3.new(1e6,1e6,1e6)
                flyBV.Velocity=Vector3.zero
            end)
        end
        if flyBV then
            local mv=Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W)         then mv=mv+Cam.CFrame.LookVector  end
            if UIS:IsKeyDown(Enum.KeyCode.S)         then mv=mv-Cam.CFrame.LookVector  end
            if UIS:IsKeyDown(Enum.KeyCode.A)         then mv=mv-Cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D)         then mv=mv+Cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space)     then mv=mv+Vector3.new(0,1,0)     end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then mv=mv-Vector3.new(0,1,0)     end
            pcall(function() flyBV.Velocity=mv.Magnitude>0 and mv.Unit*FlySpd or Vector3.zero end)
        end
    elseif flyBV then
        pcall(function() flyBV:Destroy() end); flyBV=nil
    end

    -- ── BALL SPEED TRACKING ───────────────────────────────────────────────
    -- AssemblyLinearVelocity is always 0 on client for server-physics objects.
    -- Track position delta manually instead.
    if ball then
        local now2 = tick()
        local dt2  = now2 - _czLastBallTick
        if _czLastBallPos and dt2 > 0 then
            _czBallSpeed = (_czLastBallPos - ball.Position).Magnitude / dt2
        end
        _czLastBallPos  = ball.Position
        _czLastBallTick = now2
    else
        _czBallSpeed = 0
    end

    -- ── PULL VECTOR ───────────────────────────────────────────────────────
    if PullOn and rmbHeld and ball and hrp then
        local carrier   = getBallCarrier()
        local ballInAir = carrier == nil and _czBallSpeed > 8
        if ballInAir then
            -- Use last known velocity direction from position delta
            local predicted = ball.Position + Vector3.new(0, 2, 0)
            local dist      = (predicted - hrp.Position).Magnitude
            if PullMode == 2 then
                pcall(function() hrp.CFrame = CFrame.new(predicted) end)
            elseif dist > 2 then
                local alpha = math.clamp(PullStr * PullSmooth, 0.04, 0.55)
                pcall(function() hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(predicted), alpha) end)
            end
        end
    end

    -- ── CATCH ZONE ────────────────────────────────────────────────────────
    if CatchZoneOn and ball then
        local bPos    = ball.Position
        local carrier = getBallCarrier()
        local airborne = carrier == nil and _czBallSpeed > 8

        -- Show sphere only while ball is truly airborne
        if airborne then
            if not _czBB then czBuildVisuals(CatchZoneRadius) end
            if _czBB then pcall(function() _czBB.Adornee = ball end) end
            if _czOuter then pcall(function()
                _czOuter.CFrame = CFrame.new(bPos + Vector3.new(0, 1, 0))
                if not _czPulsing then
                    local tgt = 0.72
                    if math.abs(_czOuter.Transparency - tgt) > 0.02 then
                        _czOuter.Transparency = tgt
                    end
                end
            end) end
        else
            -- Ball not airborne — destroy sphere so it doesn't get stuck
            if _czOuter or _czBB then czDestroyVisuals() end
        end

        if airborne and char and hrp then
            local closestDist = (hrp.Position - bPos).Magnitude
            local anyInZone   = closestDist < CatchZoneRadius

            if CatchZoneAssist then
                local now = tick()
                if closestDist < CatchZoneRadius and now - _czLastFire >= 0.1 then
                    _czLastFire = now

                    -- Cache CatchBox (Part, not BoolValue) once per ball spawn
                    if not _czCatchBox then
                        pcall(function()
                            local hitboxes = ball.Parent:FindFirstChild("Hitboxes")
                            if hitboxes then
                                local pBox = hitboxes:FindFirstChild(LP.Name)
                                if pBox then
                                    _czCatchBox = pBox:FindFirstChild("CatchBox")
                                end
                            end
                        end)
                    end

                    if _czCatchBox then
                        if typeof(firetouchinterest) == "function" then
                            -- Player's CatchBox "touches" the Football
                            pcall(firetouchinterest, _czCatchBox, ball, 0)
                            pcall(firetouchinterest, _czCatchBox, ball, 1)
                        elseif not _G._czFTIWarn then
                            _G._czFTIWarn = true
                            Notify("Catch Zone","firetouchinterest not on this executor",5)
                        end
                    elseif not _G._czCatchWarn then
                        _G._czCatchWarn = true
                        Notify("Catch Zone","CatchBox not found — check Hitboxes path",5)
                    end
                end
            end

            if _G.DuneCZStatus then pcall(function()
                local d = math.floor(closestDist*10)/10
                _G.DuneCZDist.Text = d.."m"
                _G.DuneCZStatus.Text = CatchZoneAssist and "⚡ ACTIVE" or "◎ "..d.."m"
                local col = anyInZone and Color3.fromRGB(90,220,120) or T.TSub
                _G.DuneCZStatus.TextColor3=col; _G.DuneCZDist.TextColor3=col
                _G.DuneCZDot.BackgroundColor3=col; _G.DuneCZCardStroke.Color=col
            end) end

            if anyInZone and not _czInZone then _czInZone=true; czPulseIn()
            elseif not anyInZone and _czInZone then
                _czInZone=false
                if not _czPulsing then czTw(Color3.fromRGB(220,170,80),0.55,0.18) end
            end

        else
            -- Ball held or on ground — reset zone state
            if _czInZone then
                _czInZone=false
                if not _czPulsing then czTw(Color3.fromRGB(220,170,80),0.72,0.18) end
            end
            if _G.DuneCZStatus then pcall(function()
                local txt = carrier and "Ball held" or "Ball on ground"
                _G.DuneCZStatus.Text=txt; _G.DuneCZStatus.TextColor3=T.TD
                if _G.DuneCZDist       then _G.DuneCZDist.Text="--" end
                if _G.DuneCZDot        then _G.DuneCZDot.BackgroundColor3=T.TD end
                if _G.DuneCZCardStroke then _G.DuneCZCardStroke.Color=T.bdr end
            end) end
        end
    elseif CatchZoneOn and not ball and _czOuter then
        czDestroyVisuals()
    elseif not CatchZoneOn and _czOuter then
        czDestroyVisuals()
    end

    -- ── TACKLE REACH ──────────────────────────────────────────────────────
    if char and TackleReachOn then
        local now=tick()
        if not _tackleReachTick or now-_tackleReachTick >= 0.25 then
            _tackleReachTick=now
            for _,v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") and (v.Name:lower():find("tackle") or v.Name:lower():find("hitbox") or v.Name:lower():find("slide")) then
                    pcall(function() v.Size=Vector3.new(TackleReachSz,TackleReachSz,TackleReachSz); v.Transparency=1; v.CanCollide=false; v.CanQuery=false end)
                end
            end
        end
    end

    -- ── AUTO FOLLOW / AUTO SACK ───────────────────────────────────────────
    if hrp then
        local carrier = getBallCarrier()
        if carrier and carrier ~= LP then
            local cHRP = carrier.Character and carrier.Character:FindFirstChild("HumanoidRootPart")
            if cHRP then
                local dist = (cHRP.Position - hrp.Position).Magnitude
                if AutoFollowOn then
                    if TPTackleOn then
                        pcall(function() hrp.CFrame = CFrame.new(cHRP.Position + Vector3.new(0,0,2)) end)
                    else
                        local alpha = math.clamp(0.15 + (1/math.max(dist,1))*2, 0.15, 0.5)
                        pcall(function() hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(cHRP.Position + Vector3.new(0,0,2)), alpha) end)
                    end
                end
                if AutoSackOn and dist <= 25 then
                    local isEnemy = carrier.Team == nil or carrier.Team ~= LP.Team
                    if isEnemy then
                        pcall(function() hrp.CFrame = CFrame.new(cHRP.Position + Vector3.new(0,0,1.5)) end)
                    end
                end
            end
        end
    end

    -- ── ANTI BLOCK ────────────────────────────────────────────────────────
    if AntiBlock1On or AntiBlock2On then
        local now=tick()
        if not _antiBlockTick or now-_antiBlockTick >= 0.5 then
            _antiBlockTick=now
            for _,p in ipairs(Players:GetPlayers()) do
                if p==LP then continue end
                local pchar=p.Character; if not pchar then continue end
                for _,v in ipairs(pchar:GetDescendants()) do
                    if v:IsA("BasePart") then
                        local n=v.Name:lower()
                        if AntiBlock1On and (n:find("block") or n:find("shield") or n:find("protect")) then
                            pcall(function() v.Size=Vector3.new(0.01,0.01,0.01) end)
                        end
                        if AntiBlock2On and (n:find("blocker") or n:find("wall") or n:find("barrier")) then
                            pcall(function() v.Size=Vector3.new(0.01,0.01,0.01) end)
                        end
                    end
                end
            end
        end
    end

end) -- end Heartbeat

