-- ‚ĒÄ‚ĒÄ BALL TRACKING ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
local _ball = nil
local _ballConns = {}

-- FIX 1: _ballFFParts and both FF functions moved ABOVE watchBall so they exist when called
local _ballFFParts = {}

local function makeBallFF(ball)
    if _ballFFParts[ball] then return end
    local part = Instance.new("Part")
    part.Shape        = Enum.PartType.Ball
    part.Size         = Vector3.new(25, 25, 25)
    part.Color        = T.acc
    part.Material     = Enum.Material.Neon
    part.Transparency = 0.82
    part.CanCollide   = false
    part.CanQuery     = false
    part.CastShadow   = false
    part.Anchored     = true
    part.Name         = "DuneBallFF"
    part.CFrame       = CFrame.new(ball.Position)
    part.Parent       = workspace  -- FIX 5: always parent to workspace, visibility controlled via Transparency
    _ballFFParts[ball] = part
    -- If FF is off right now, hide it immediately
    if not BallFFOn then
        part.Transparency = 1
    end
end

local function destroyBallFF(ball)
    local part = _ballFFParts[ball]
    if part then
        pcall(function() part:Destroy() end)
        _ballFFParts[ball] = nil
    end
end

local function resetCatchParts()
    local char = LP.Character; if not char then return end
    for _, n in ipairs({"CatchLeft", "CatchRight"}) do
        local pt = char:FindFirstChild(n)
        if pt then
            pcall(function()
                pt.Size = Vector3.new(1,1,1)
                pt.Transparency = 0
                pt.CanCollide = true
                pt.CanQuery = true
            end)
        end
    end
    _ball = nil
end

local function watchBall(ball)
    if _ballConns[ball] then return end
    -- Now safe: makeBallFF and destroyBallFF are defined above
    if BallFFOn then makeBallFF(ball) end
    _ballConns[ball] = ball.Destroying:Connect(function()
        if _ball == ball then _ball = nil end
        resetCatchParts()
        destroyBallFF(ball)
        _ballConns[ball] = nil
    end)
end

-- FIX 2: Optimized getBall ‚ÄĒ no descendant scan while cached ball is valid
local function getBall()
    if _ball and _ball.Parent then return _ball end
    _ball = nil
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name == "Football" and v:IsA("BasePart") then
            _ball = v; watchBall(v); return v
        end
        if v:IsA("Model") then
            local fb = v:FindFirstChild("Football")
            if fb and fb:IsA("BasePart") then
                _ball = fb; watchBall(fb); return fb
            end
        end
    end
    return nil
end

-- FIX 2: ChildAdded only (removed DescendantAdded ‚ÄĒ it fired on every GUI/part change in the entire game causing massive lag)
conn(workspace.ChildAdded, function(child)
    if child.Name == "Football" and child:IsA("BasePart") then
        _ball = child
        watchBall(child)
    end
    if child:IsA("Model") then
        local fb = child:FindFirstChild("Football")
        if fb and fb:IsA("BasePart") then
            _ball = fb; watchBall(fb)
        end
        child.ChildAdded:Connect(function(v)
            if v.Name == "Football" and v:IsA("BasePart") and not _ballConns[v] then
                _ball = v; watchBall(v)
            end
        end)
    end
end)

local function getBallCarrier()
    local ball = getBall()
    if not ball then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        local char = p.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and (ball.Position - hrp.Position).Magnitude < 6 then
            return p
        end
    end
    return nil
end

-- FIX: getPower keys cached as upvalue ‚ÄĒ was rebuilding and re-sorting every frame
local _PT = {[10]=55,[20]=60,[30]=65,[35]=70,[40]=75,[50]=80,[60]=85,[70]=90,[80]=95,[100]=98,[120]=100}
local _PTKeys = (function()
    local keys = {}
    for k in pairs(_PT) do table.insert(keys, k) end
    table.sort(keys)
    return keys
end)()

local function getPower(dist)
    for i = 1, #_PTKeys - 1 do
        if dist >= _PTKeys[i] and dist <= _PTKeys[i+1] then
            local t2 = (dist - _PTKeys[i]) / (_PTKeys[i+1] - _PTKeys[i])
            return math.floor(_PT[_PTKeys[i]] + (_PT[_PTKeys[i+1]] - _PT[_PTKeys[i]]) * t2 + 0.5)
        end
    end
    return dist < _PTKeys[1] and _PT[_PTKeys[1]] or _PT[_PTKeys[#_PTKeys]]
end

