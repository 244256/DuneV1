-- ── LONG ARMS LOOP ────────────────────────────────────────────────────────
-- R15 names first, R6 fallbacks included
local ARM_PARTS = {"LeftHand","RightHand","LeftLowerArm","RightLowerArm",
                   "LeftUpperArm","RightUpperArm","Left Arm","Right Arm"}
local _armOrigSizes = {}
local _armOrigTrans = {}

local function saveArmOriginals(char)
    for _, name in ipairs(ARM_PARTS) do
        local p = char:FindFirstChild(name)
        if p and not _armOrigSizes[name] then
            _armOrigSizes[name] = p.Size
            _armOrigTrans[name] = p.Transparency
        end
    end
end

local function applyArmReach(char, sz)
    local scale = sz / 10
    for _, name in ipairs(ARM_PARTS) do
        local p = char:FindFirstChild(name)
        if p then
            pcall(function()
                local orig = _armOrigSizes[name] or p.Size
                p.Size = Vector3.new(
                    orig.X * math.max(1, scale * 0.6),
                    orig.Y * scale,
                    orig.Z * math.max(1, scale * 0.6)
                )
                p.Transparency = 0
            end)
        end
    end
    local catchSz = sz * 2
    for _, name in ipairs({"CatchLeft","CatchRight"}) do
        local p = char:FindFirstChild(name)
        if p then
            pcall(function()
                p.Size = Vector3.new(catchSz, catchSz, catchSz)
                p.CanTouch = true; p.CanCollide = false
                p.CanQuery = false; p.Massless = true
            end)
        end
    end
end

local function resetArmReach(char)
    for _, name in ipairs(ARM_PARTS) do
        local p = char:FindFirstChild(name)
        if p then
            pcall(function()
                if _armOrigSizes[name] then
                    p.Size = _armOrigSizes[name]
                    p.Transparency = _armOrigTrans[name] or 0
                end
            end)
        end
    end
    _armOrigSizes = {}; _armOrigTrans = {}
end

conn(RS.Stepped, function()
    if Unloaded then return end
    local char = LP.Character; if not char then return end
    if ReachOn then
        saveArmOriginals(char)
        applyArmReach(char, ReachSz)
    else
        if next(_armOrigSizes) ~= nil then resetArmReach(char) end
    end
end)

