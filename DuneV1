-- ── BALL TRACKING ──────────────────────────────────────────────────────────
local _ball     = nil
local _ballConns = {}

local function resetCatchParts()
    local char = LP.Character; if not char then return end
    for _, n in ipairs({"CatchLeft", "CatchRight"}) do
        local pt = char:FindFirstChild(n)
        if pt then
            pcall(function()
                pt.Size = Vector3.new(1,1,1)
                pt.Transparency = 0
                pt.CanCollide = true
                pt.CanQuery = true
            end)
        end
    end
    _ball = nil
end

local function watchBall(ball)
    if _ballConns[ball] then return end
    _ballConns[ball] = ball.Destroying:Connect(function()
        if _ball == ball then _ball = nil end
        resetCatchParts()
        czDestroyVisuals()
        _czCatchBox    = nil; _czLastFire=0
        _czLastBallPos = nil; _czBallSpeed=0
        _G._czCatchWarn=nil;  _G._czFTIWarn=nil
        _ballConns[ball] = nil
    end)
end

-- Watch for drive changes: UFB reuses the ball but swaps Hitboxes children
-- between drives. When our player's hitbox folder changes, reset the cache.
local function watchHitboxes()
    local hitboxes = nil
    -- Poll for Hitboxes folder since ball may not exist yet
    task.spawn(function()
        while not Unloaded do
            task.wait(2) -- poll every 2s — less overhead than 1s
            local b = getBall()
            if b and b.Parent then
                local hb = b.Parent:FindFirstChild("Hitboxes")
                if hb and hb ~= hitboxes then
                    hitboxes = hb
                    -- New hitboxes folder = new drive, reset CatchBox cache
                    _czCatchBox    = nil
                    _czLastFire    = 0
                    _czLastBallPos = nil
                    _czBallSpeed   = 0
                    -- Watch for child changes within this drive's hitboxes
                    hb.ChildAdded:Connect(function()
                        _czCatchBox = nil  -- force re-lookup when roster changes
                    end)
                    hb.ChildRemoved:Connect(function()
                        _czCatchBox = nil
                    end)
                end
            end
        end
    end)
end
watchHitboxes()

local function getBall()
    -- Return cached reference immediately — ball is found at startup and never rescanned
    if _ball and _ball.Parent then return _ball end
    _ball = nil
    return nil
end

-- Find ball once at startup then rely purely on DescendantAdded for respawns
task.spawn(function()
    -- Try immediately first
    for _, v in ipairs(workspace:GetDescendants()) do
        if v.Name == "Football" and (v:IsA("MeshPart") or v:IsA("BasePart")) then
            _ball = v; watchBall(v); break
        end
    end
    -- Then watch for new ones
    local descConn
    descConn = workspace.DescendantAdded:Connect(function(v)
        if v.Name == "Football" and (v:IsA("MeshPart") or v:IsA("BasePart")) then
            if not _ball then _ball = v; watchBall(v) end
        end
    end)
    table.insert(Conns, descConn)
end)

-- FIX 3: carrier proximity threshold reduced 10 → 4 studs.
-- At 10 studs, the QB still registers as "holding" the ball for several frames
-- after throwing, which sets ballInAir = false and blocks pull vector entirely.
-- 4 studs means only someone truly holding the ball counts.
local function getBallCarrier()
    local ball = getBall()
    if not ball then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        local char = p.Character
        if not char then continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and (ball.Position - hrp.Position).Magnitude < 4 then
            return p
        end
    end
    return nil
end

local _PT = {[10]=55,[20]=60,[30]=65,[35]=70,[40]=75,[50]=80,[60]=85,[70]=90,[80]=95,[100]=98,[120]=100}
local _PTKeys = (function()
    local keys = {}
    for k in pairs(_PT) do table.insert(keys, k) end
    table.sort(keys); return keys
end)()

local function getPower(dist)
    for i = 1, #_PTKeys - 1 do
        if dist >= _PTKeys[i] and dist <= _PTKeys[i+1] then
            local t2 = (dist - _PTKeys[i]) / (_PTKeys[i+1] - _PTKeys[i])
            return math.floor(_PT[_PTKeys[i]] + (_PT[_PTKeys[i+1]] - _PT[_PTKeys[i]]) * t2 + 0.5)
        end
    end
    return dist < _PTKeys[1] and _PT[_PTKeys[1]] or _PT[_PTKeys[#_PTKeys]]
end

