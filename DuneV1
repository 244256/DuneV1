    if ord then h.LayoutOrder = ord end
    local tr = Instance.new("Frame", h); tr.Size = UDim2.new(1,0,0,16); tr.BackgroundTransparency = 1
    local lb = Instance.new("TextLabel", tr)
    lb.Size = UDim2.new(.6,0,1,0); lb.BackgroundTransparency = 1; lb.Font = Enum.Font.Gotham
    lb.TextSize = 11; lb.TextColor3 = T.TSub; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.Text = txt
    local vl = Instance.new("TextLabel", tr)
    vl.Size = UDim2.new(.38,0,1,0); vl.Position = UDim2.new(.62,0,0,0)
    vl.BackgroundTransparency = 1; vl.Font = Enum.Font.GothamBold; vl.TextSize = 11
    vl.TextColor3 = T.TP; vl.TextXAlignment = Enum.TextXAlignment.Right; vl.Text = tostring(def)
    if tip then
        local tb = mkTip(tr, tip); tb.AnchorPoint = Vector2.new(1,.5)
        tb.Position = UDim2.new(1,0,.5,0)
    end
    local tk = Instance.new("Frame", h)
    tk.Position = UDim2.new(0,0,0,24); tk.Size = UDim2.new(1,0,0,5)
    tk.BackgroundColor3 = T.btn; tk.BorderSizePixel = 0; corner(tk, UDim.new(1,0)); mkStroke(tk, T.bdr)
    local fl = Instance.new("Frame", tk)
    fl.Size = UDim2.new((def-mn)/(mx-mn),0,1,0); fl.BackgroundColor3 = T.acc
    fl.BorderSizePixel = 0; corner(fl, UDim.new(1,0))
    local th = Instance.new("Frame", tk)
    th.Size = UDim2.fromOffset(13,13); th.AnchorPoint = Vector2.new(.5,.5)
    th.Position = UDim2.new((def-mn)/(mx-mn),0,.5,0); th.BackgroundColor3 = T.cream
    th.BorderSizePixel = 0; corner(th, UDim.new(1,0)); mkStroke(th, T.acc)
    local hitbox = Instance.new("TextButton", h)
    hitbox.Size = UDim2.new(1,0,0,44); hitbox.Position = UDim2.new(0,0,0,0)
    hitbox.BackgroundTransparency = 1; hitbox.BorderSizePixel = 0
    hitbox.Text = ""; hitbox.ZIndex = 10
    cb(def)
    local drag = false; local touchX = 0
    conn(hitbox.InputBegan, function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            drag=true; touchX=i.Position.X
        end
    end)
    conn(UIS.InputChanged, function(i)
        if not drag then return end
        if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
            touchX=i.Position.X
        end
    end)
    conn(UIS.InputEnded, function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then drag=false end
    end)
    conn(RS.RenderStepped, function()
        if Unloaded or not drag then return end
        local pct = math.clamp((touchX-tk.AbsolutePosition.X)/tk.AbsoluteSize.X, 0, 1)
        local val = math.clamp(math.floor((mn+(mx-mn)*pct)/step+.5)*step, mn, mx)
        local sp  = (val-mn)/(mx-mn)
        fl.Size = UDim2.new(sp,0,1,0); th.Position = UDim2.new(sp,0,.5,0)
        vl.Text = tostring(val); cb(val)
    end)
end

local function Drop(p, txt, opts, di, cb, ord)
    local con = Instance.new("Frame", p)
    con.Size = UDim2.new(1,0,0,46); con.BackgroundTransparency = 1; con.ClipsDescendants = false
    if ord then con.LayoutOrder = ord end
    local lb = Instance.new("TextLabel", con)
    lb.Size = UDim2.new(1,0,0,16); lb.BackgroundTransparency = 1; lb.Font = Enum.Font.Gotham
    lb.TextSize = 11; lb.TextColor3 = T.TSub; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.Text = txt
    local btn = Instance.new("TextButton", con)
    btn.Size = UDim2.new(1,0,0,26); btn.Position = UDim2.fromOffset(0,18)
    btn.BackgroundColor3 = T.btn; btn.BorderSizePixel = 0; btn.Font = Enum.Font.Gotham
    btn.TextSize = 11; btn.TextColor3 = T.TP; btn.TextXAlignment = Enum.TextXAlignment.Left
    corner(btn, UDim.new(0,7)); mkStroke(btn, T.bdr)
    Instance.new("UIPadding", btn).PaddingLeft = UDim.new(0,10)
    local chv = Instance.new("TextLabel", btn)
    chv.Size = UDim2.fromOffset(20,26); chv.Position = UDim2.new(1,-24,0,0)
    chv.BackgroundTransparency = 1; chv.Font = Enum.Font.GothamBold; chv.TextSize = 10
    chv.TextColor3 = T.TD; chv.Text = "▾"

    local curIdx = di; btn.Text = opts[curIdx]; cb(curIdx)
    local lh = #opts * 28 + 10

    -- dl lives in SG so it floats above everything.
    -- NO ClipsDescendants — that was blocking clicks on items.
    -- We show/hide via Visible + a quick fade instead of size tween.
    local dl = Instance.new("Frame", SG)
    dl.BackgroundColor3 = T.card; dl.BorderSizePixel = 0
    dl.ZIndex = 220; dl.Visible = false
    dl.ClipsDescendants = false   -- MUST be false so items are always hittable
    corner(dl, UDim.new(0,7)); mkStroke(dl, T.bdr)
    local dll = Instance.new("UIListLayout", dl)
    dll.Padding = UDim.new(0,2); dll.SortOrder = Enum.SortOrder.LayoutOrder
    local dlp = Instance.new("UIPadding", dl)
    dlp.PaddingTop=UDim.new(0,4); dlp.PaddingBottom=UDim.new(0,4)
    dlp.PaddingLeft=UDim.new(0,4); dlp.PaddingRight=UDim.new(0,4)

    local open = false

    local function updateColors()
        for _,ch in ipairs(dl:GetChildren()) do
            if ch:IsA("TextButton") then
                ch.TextColor3 = ch.Text == opts[curIdx] and T.acc or T.TSub
            end
        end
    end

    local function close()
        if not open then return end
        open = false
        dl.Visible = false
        tw(chv, {Rotation=0}, .12)
    end

    for i, opt in ipairs(opts) do
        local it = Instance.new("TextButton", dl)
        it.LayoutOrder = i
        it.Size = UDim2.new(1,0,0,24)
        it.BackgroundColor3 = T.btn
        it.Font = Enum.Font.Gotham; it.TextSize = 11
        it.TextColor3 = i==curIdx and T.acc or T.TSub
        it.TextXAlignment = Enum.TextXAlignment.Left
        it.Text = opt; it.BorderSizePixel = 0
        it.ZIndex = 222; it.Active = true
        corner(it, UDim.new(0,5))
        Instance.new("UIPadding", it).PaddingLeft = UDim.new(0,8)
        conn(it.MouseEnter, function() tw(it,{BackgroundColor3=T.btnH},.1) end)
        conn(it.MouseLeave, function() tw(it,{BackgroundColor3=T.btn},.1) end)
        -- Activated fires reliably for both mouse and touch, unlike MouseButton1Click
        -- which can be blocked by parent ClipsDescendants or scroll containers
        it.Activated:Connect(function()
            curIdx = i
            btn.Text = opt
            cb(i)
            updateColors()
            close()
        end)
    end

    btn.Activated:Connect(function()
        if open then close(); return end
        local ap = btn.AbsolutePosition
        local as = btn.AbsoluteSize
        if as.X == 0 then return end
        open = true
        dl.Size     = UDim2.fromOffset(as.X, lh)
        dl.Position = UDim2.fromOffset(ap.X, ap.Y + as.Y + 2)
        dl.Visible  = true
        tw(chv, {Rotation=180}, .14)
        updateColors()
    end)

    -- Close when clicking anywhere outside
    conn(UIS.InputBegan, function(inp, gp)
        if gp or not open then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1
        and inp.UserInputType ~= Enum.UserInputType.Touch then return end
        task.defer(function()
            if not open then return end
            local mp = UIS:GetMouseLocation()
            local function inside(f)
                local fp=f.AbsolutePosition; local fs=f.AbsoluteSize
                return mp.X>=fp.X and mp.X<=fp.X+fs.X and mp.Y>=fp.Y and mp.Y<=fp.Y+fs.Y
            end
            if not inside(dl) and not inside(btn) then close() end
        end)
    end)
end

