-- FIX 1: guard checkcaller — if the executor doesn't expose it, default to
-- returning true so the hook never errors on normal game.__index reads.
-- Without this guard, every game:GetService() call would crash silently,
-- killing the Heartbeat and all movement/pull features.
local _cc = typeof(checkcaller) == "function" and checkcaller or function() return true end

local _acOld
pcall(function()
    local rng = Random.new()
    _acOld = hookmetamethod(game, "__index", function(self, key)
        -- guard: only intercept external calls
        if not _cc() then
            if key == "WalkSpeed" then return 16 end
            if key == "JumpPower" then return 50 end
        end
        -- always forward — never return nil for game.__index keys
        -- rawget(getmetatable(self) or {}, key) can fail on some executors;
        -- use pcall and fall back to the original hook.
        if _acOld then
            local ok, v = pcall(_acOld, self, key)
            if ok then return v end
        end
        return nil
    end)
end)

